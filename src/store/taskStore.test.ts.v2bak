import { useTaskStore } from './taskStore';
import { Task } from '../types';
import { scheduleTaskNotification, cancelTaskNotification } from '../services/notificationService';

// Mock notification service
jest.mock('../services/notificationService', () => ({
  scheduleTaskNotification: jest.fn(),
  cancelTaskNotification: jest.fn(),
  rescheduleAllNotifications: jest.fn()
}));

const mockScheduleTaskNotification = scheduleTaskNotification as jest.MockedFunction<typeof scheduleTaskNotification>;
const mockCancelTaskNotification = cancelTaskNotification as jest.MockedFunction<typeof cancelTaskNotification>;

describe('Task Store', () => {
  beforeEach(() => {
    // Clear mock calls and reset store
    jest.clearAllMocks();
    const store = useTaskStore.getState();
    store.clearTasks();
  });

  describe('addTask', () => {
    it('should add a new task and schedule notification', async () => {
      const store = useTaskStore.getState();
      
      const newTask: Omit<Task, 'id' | 'createdAt' | 'subtasks'> = {
        title: 'Test Task',
        dueDate: new Date().toISOString(),
        priority: 'medium',
        startDate: new Date().toISOString(),
        taskType: 'single',
        recurrence: {
          enabled: false,
          type: 'daily',
          interval: 1,
          days: [],
          end: { type: 'never' },
          exceptions: []
        },
        reminderEnabled: true,
        notificationId: 123,
        completed: false,
        completedDates: []
      };

      // 等待状态更新
      await new Promise(resolve => {
        store.addTask(newTask);
        // 立即检查，因为zustand的set是同步的
        setTimeout(resolve, 0);
      });

      // 再次获取store的状态
      const updatedStore = useTaskStore.getState();
      expect(updatedStore.tasks.length).toBe(1);
      expect(updatedStore.tasks[0].title).toBe('Test Task');
      expect(mockScheduleTaskNotification).toHaveBeenCalledWith(expect.objectContaining({
        title: 'Test Task',
        reminderEnabled: true
      }));
    });

    it('should add a task without scheduling notification when reminder is disabled', async () => {
      const store = useTaskStore.getState();
      
      const newTask: Omit<Task, 'id' | 'createdAt' | 'subtasks'> = {
        title: 'Test Task',
        dueDate: new Date().toISOString(),
        priority: 'medium',
        startDate: new Date().toISOString(),
        taskType: 'single',
        recurrence: {
          enabled: false,
          type: 'daily',
          interval: 1,
          days: [],
          end: { type: 'never' },
          exceptions: []
        },
        reminderEnabled: false,
        notificationId: 0,
        completed: false,
        completedDates: []
      };

      // 等待状态更新
      await new Promise(resolve => {
        store.addTask(newTask);
        setTimeout(resolve, 0);
      });

      // 再次获取store的状态
      const updatedStore = useTaskStore.getState();
      expect(updatedStore.tasks.length).toBe(1);
      expect(mockScheduleTaskNotification).not.toHaveBeenCalled();
    });
  });

  describe('updateTask', () => {
    it('should update an existing task and reschedule notification', async () => {
      const store = useTaskStore.getState();
      
      // Add a task first
      const initialTask: Omit<Task, 'id' | 'createdAt' | 'subtasks'> = {
        title: 'Initial Task',
        dueDate: new Date().toISOString(),
        priority: 'medium',
        startDate: new Date().toISOString(),
        taskType: 'single',
        recurrence: {
          enabled: false,
          type: 'daily',
          interval: 1,
          days: [],
          end: { type: 'never' },
          exceptions: []
        },
        reminderEnabled: true,
        notificationId: 123,
        completed: false,
        completedDates: []
      };

      await new Promise(resolve => {
        store.addTask(initialTask);
        setTimeout(resolve, 0);
      });
      
      // 再次获取store的状态
      const storeAfterAdd = useTaskStore.getState();
      const taskId = storeAfterAdd.tasks[0].id;

      // Update the task
      await new Promise(resolve => {
        store.updateTask(taskId, {
          title: 'Updated Task',
          reminderEnabled: true
        });
        setTimeout(resolve, 0);
      });

      // 再次获取store的状态
      const storeAfterUpdate = useTaskStore.getState();
      expect(storeAfterUpdate.tasks[0].title).toBe('Updated Task');
      expect(mockCancelTaskNotification).toHaveBeenCalledWith(expect.objectContaining({
        id: taskId
      }));
      expect(mockScheduleTaskNotification).toHaveBeenCalledWith(expect.objectContaining({
        title: 'Updated Task',
        reminderEnabled: true
      }));
    });

    it('should update a task and cancel notification when reminder is disabled', async () => {
      const store = useTaskStore.getState();
      
      // Add a task first
      const initialTask: Omit<Task, 'id' | 'createdAt' | 'subtasks'> = {
        title: 'Initial Task',
        dueDate: new Date().toISOString(),
        priority: 'medium',
        startDate: new Date().toISOString(),
        taskType: 'single',
        recurrence: {
          enabled: false,
          type: 'daily',
          interval: 1,
          days: [],
          end: { type: 'never' },
          exceptions: []
        },
        reminderEnabled: true,
        notificationId: 123,
        completed: false,
        completedDates: []
      };

      await new Promise(resolve => {
        store.addTask(initialTask);
        setTimeout(resolve, 0);
      });
      
      // 再次获取store的状态
      const storeAfterAdd = useTaskStore.getState();
      const taskId = storeAfterAdd.tasks[0].id;

      // Update the task to disable reminder
      await new Promise(resolve => {
        store.updateTask(taskId, {
          title: 'Updated Task',
          reminderEnabled: false
        });
        setTimeout(resolve, 0);
      });

      // 再次获取store的状态
      const storeAfterUpdate = useTaskStore.getState();
      expect(storeAfterUpdate.tasks[0].title).toBe('Updated Task');
      expect(storeAfterUpdate.tasks[0].reminderEnabled).toBe(false);
      expect(mockCancelTaskNotification).toHaveBeenCalledWith(expect.objectContaining({
        id: taskId
      }));
      // 重置mock调用计数，因为添加任务时已经调用过scheduleTaskNotification
      jest.clearAllMocks();
      // 验证在更新任务时没有调用scheduleTaskNotification
      expect(mockScheduleTaskNotification).not.toHaveBeenCalled();
    });
  });

  describe('deleteTask', () => {
    it('should delete a task and cancel its notification', async () => {
      const store = useTaskStore.getState();
      
      // Add a task first
      const newTask: Omit<Task, 'id' | 'createdAt' | 'subtasks'> = {
        title: 'Test Task',
        dueDate: new Date().toISOString(),
        priority: 'medium',
        startDate: new Date().toISOString(),
        taskType: 'single',
        recurrence: {
          enabled: false,
          type: 'daily',
          interval: 1,
          days: [],
          end: { type: 'never' },
          exceptions: []
        },
        reminderEnabled: true,
        notificationId: 123,
        completed: false,
        completedDates: []
      };

      await new Promise(resolve => {
        store.addTask(newTask);
        setTimeout(resolve, 0);
      });
      
      // 再次获取store的状态
      const storeAfterAdd = useTaskStore.getState();
      const taskId = storeAfterAdd.tasks[0].id;

      // Delete the task
      await new Promise(resolve => {
        store.deleteTask(taskId);
        setTimeout(resolve, 0);
      });

      // 再次获取store的状态
      const storeAfterDelete = useTaskStore.getState();
      expect(storeAfterDelete.tasks.length).toBe(0);
      expect(mockCancelTaskNotification).toHaveBeenCalledWith(expect.objectContaining({
        id: taskId
      }));
    });
  });

  describe('toggleTaskCompleted', () => {
    it('should mark a task as completed and cancel its notification', async () => {
      const store = useTaskStore.getState();
      
      // Add a task first
      const newTask: Omit<Task, 'id' | 'createdAt' | 'subtasks'> = {
        title: 'Test Task',
        dueDate: new Date().toISOString(),
        priority: 'medium',
        startDate: new Date().toISOString(),
        taskType: 'single',
        recurrence: {
          enabled: false,
          type: 'daily',
          interval: 1,
          days: [],
          end: { type: 'never' },
          exceptions: []
        },
        reminderEnabled: true,
        notificationId: 123,
        completed: false,
        completedDates: []
      };

      await new Promise(resolve => {
        store.addTask(newTask);
        setTimeout(resolve, 0);
      });
      
      // 再次获取store的状态
      const storeAfterAdd = useTaskStore.getState();
      const taskId = storeAfterAdd.tasks[0].id;

      // Mark as completed
      await new Promise(resolve => {
        store.toggleTaskCompleted(taskId);
        setTimeout(resolve, 0);
      });

      // 再次获取store的状态
      const storeAfterToggle = useTaskStore.getState();
      expect(storeAfterToggle.tasks[0].completed).toBe(true);
      expect(mockCancelTaskNotification).toHaveBeenCalledWith(expect.objectContaining({
        id: taskId
      }));
    });

    it('should mark a task as incomplete and reschedule its notification', async () => {
      const store = useTaskStore.getState();
      
      // Add a task first
      const newTask: Omit<Task, 'id' | 'createdAt' | 'subtasks'> = {
        title: 'Test Task',
        dueDate: new Date().toISOString(),
        priority: 'medium',
        startDate: new Date().toISOString(),
        taskType: 'single',
        recurrence: {
          enabled: false,
          type: 'daily',
          interval: 1,
          days: [],
          end: { type: 'never' },
          exceptions: []
        },
        reminderEnabled: true,
        notificationId: 123,
        completed: false,
        completedDates: []
      };

      await new Promise(resolve => {
        store.addTask(newTask);
        setTimeout(resolve, 0);
      });
      
      // 再次获取store的状态
      const storeAfterAdd = useTaskStore.getState();
      const taskId = storeAfterAdd.tasks[0].id;

      // Mark as completed first
      await new Promise(resolve => {
        store.toggleTaskCompleted(taskId);
        setTimeout(resolve, 0);
      });
      
      // 再次获取store的状态
      const storeAfterFirstToggle = useTaskStore.getState();
      expect(storeAfterFirstToggle.tasks[0].completed).toBe(true);

      // Clear mock calls
      jest.clearAllMocks();

      // Mark as incomplete
      await new Promise(resolve => {
        store.toggleTaskCompleted(taskId);
        setTimeout(resolve, 0);
      });

      // 再次获取store的状态
      const storeAfterSecondToggle = useTaskStore.getState();
      expect(storeAfterSecondToggle.tasks[0].completed).toBe(false);
      expect(mockScheduleTaskNotification).toHaveBeenCalledWith(expect.objectContaining({
        id: taskId,
        reminderEnabled: true
      }));
    });
  });

  describe('clearTasks', () => {
    it('should clear all tasks and cancel their notifications', async () => {
      const store = useTaskStore.getState();
      
      // Add some tasks
      const task1: Omit<Task, 'id' | 'createdAt' | 'subtasks'> = {
        title: 'Task 1',
        dueDate: new Date().toISOString(),
        priority: 'medium',
        startDate: new Date().toISOString(),
        taskType: 'single',
        recurrence: {
          enabled: false,
          type: 'daily',
          interval: 1,
          days: [],
          end: { type: 'never' },
          exceptions: []
        },
        reminderEnabled: true,
        notificationId: 123,
        completed: false,
        completedDates: []
      };

      const task2: Omit<Task, 'id' | 'createdAt' | 'subtasks'> = {
        title: 'Task 2',
        dueDate: new Date().toISOString(),
        priority: 'high',
        startDate: new Date().toISOString(),
        taskType: 'recurring',
        recurrence: {
          enabled: true,
          type: 'daily',
          interval: 1,
          days: [],
          end: { type: 'never' },
          exceptions: []
        },
        reminderEnabled: false,
        notificationId: 0,
        completed: false,
        completedDates: []
      };

      await new Promise(resolve => {
        store.addTask(task1);
        setTimeout(resolve, 0);
      });
      await new Promise(resolve => {
        store.addTask(task2);
        setTimeout(resolve, 0);
      });

      // 再次获取store的状态
      const storeAfterAdd = useTaskStore.getState();
      expect(storeAfterAdd.tasks.length).toBe(2);

      // Clear tasks
      await new Promise(resolve => {
        store.clearTasks();
        setTimeout(resolve, 0);
      });

      // 再次获取store的状态
      const storeAfterClear = useTaskStore.getState();
      expect(storeAfterClear.tasks.length).toBe(0);
      // 验证cancelTaskNotification被调用至少一次（因为task1有notificationId）
      expect(mockCancelTaskNotification).toHaveBeenCalled();
    });
  });

  describe('loadTasks', () => {
    it('should load tasks from storage', async () => {
      const store = useTaskStore.getState();
      
      // Add some tasks
      const task1: Omit<Task, 'id' | 'createdAt' | 'subtasks'> = {
        title: 'Task 1',
        dueDate: new Date().toISOString(),
        priority: 'medium',
        startDate: new Date().toISOString(),
        taskType: 'single',
        recurrence: {
          enabled: false,
          type: 'daily',
          interval: 1,
          days: [],
          end: { type: 'never' },
          exceptions: []
        },
        reminderEnabled: true,
        notificationId: 123,
        completed: false,
        completedDates: []
      };

      await new Promise(resolve => {
        store.addTask(task1);
        setTimeout(resolve, 0);
      });
      
      // 再次获取store的状态
      const storeAfterAdd = useTaskStore.getState();
      expect(storeAfterAdd.tasks.length).toBe(1);

      // Load tasks
      store.loadTasks();

      // Just verify the method doesn't throw an error
      const storeAfterLoad = useTaskStore.getState();
      expect(storeAfterLoad.tasks.length).toBe(1);
    });
  });
});